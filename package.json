{
  "name": "@devdatalab/ddl-charts",
  "version": "0.1.1",
  "description": "D3-based charting library for DDL - OWID-inspired interactive data visualizations",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./assets/logo.js": "./src/assets/logo.js",
    "./styles/ddl-theme.css": "./src/styles/ddl-theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "!src/**/*.test.js",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devdatalab/ddl-charts.git"
  },
  "homepage": "https://github.com/devdatalab/ddl-charts#readme",
  "bugs": {
    "url": "https://github.com/devdatalab/ddl-charts/issues"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "render:examples": "node scripts/render-examples.mjs"
  },
  "keywords": [
    "d3",
    "visualization",
    "charts",
    "interactive",
    "svg"
  ],
  "author": "Dev Data Lab",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@vitest/ui": "^2.0.0",
    "jsdom": "^25.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
